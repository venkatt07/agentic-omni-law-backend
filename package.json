{
  "name": "agentic-omni-law-backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "check": "tsc -p tsconfig.json --noEmit",
    "db:url": "node scripts/print_database_url.mjs",
    "db:init": "node scripts/init_schema.mjs",
    "ai:download:ps": "powershell -ExecutionPolicy Bypass -File ./scripts/download_models.ps1",
    "ai:download:sh": "bash ./scripts/download_models.sh",
    "ai:start:gen": "powershell -ExecutionPolicy Bypass -File ./scripts/start_llm_server.ps1",
    "ai:start:preview": "powershell -ExecutionPolicy Bypass -File ./scripts/start_llm_preview_server.ps1",
    "ai:start:final": "powershell -ExecutionPolicy Bypass -File ./scripts/start_llm_server.ps1",
    "ai:start:embed": "powershell -ExecutionPolicy Bypass -File ./scripts/start_embed_server.ps1",
    "ai:verify": "node scripts/verify_ai_runtime.mjs",
    "ai:bench": "node scripts/bench_ai.mjs",
    "ai:eval": "node scripts/eval_rag.mjs",
    "test:role-agents": "tsx --test tests/roleAgents/index.test.ts",
    "scan:no-vendor": "node scripts/no_vendor_name_scan.mjs",
    "legal:bootstrap": "python scripts/bootstrap_legal_corpus.py --starter",
    "legal:bootstrap:dry": "python scripts/bootstrap_legal_corpus.py --dry-run",
    "legal:index": "tsx scripts/index_legal_corpus.ts",
    "legal:index:force": "tsx scripts/index_legal_corpus.ts --force"
  },
  "dependencies": {
    "@types/pdfkit": "^0.17.5",
    "bcrypt": "^5.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^5.0.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.8.0",
    "multer": "^1.4.5-lts.1",
    "mysql2": "^3.18.0",
    "nodemailer": "^6.9.16",
    "pdf-parse": "^1.1.1",
    "pdfkit": "^0.17.2",
    "tesseract.js": "^5.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.19.0",
    "@types/nodemailer": "^6.4.17",
    "tsx": "^4.20.5",
    "typescript": "5.6.3"
  }
}
